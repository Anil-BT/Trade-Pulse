# Optional broker tokens (can also paste in the UI)
UPSTOX_ACCESS_TOKEN=
DHAN_ACCESS_TOKEN=
DHAN_CLIENT_ID=
KITE_API_KEY=
KITE_ACCESS_TOKEN=

# Optional Firebase (Auth + Firestore strategy sync)
# Project Settings → Your apps → Web config
# Full steps: docs/FIREBASE.md
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Required for durable paper trading on Vercel (server Admin SDK).
# Firebase Console → Project settings → Service accounts → Generate new private key.
# Paste the entire JSON as ONE line (keep \n in private_key as \\n is fine).
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN...","client_email":"..."}
FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional: protect /api/paper/session/worker cron
CRON_SECRET=

# Optional: Market Watch Telegram alerts (new screener signals)
# 1) Message @BotFather → /newbot → copy token
# 2) Add bot to your group, send a message, get chat id via
#    https://api.telegram.org/bot<TOKEN>/getUpdates  (look for "chat":{"id":-100...})
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
